<!-- Exclusive Section -->
{{ 'exclusive-section.css' | asset_url | stylesheet_tag }}

<section class="exclusive-section"
  style="
    {% if section.settings.background_image %}background-image: url('{{ section.settings.background_image | image_url }}');{% endif %}
  "
  data-bg-desktop="{% if section.settings.background_image %}{{ section.settings.background_image | image_url }}{% endif %}"
  data-bg-mobile="{% if section.settings.background_image_mobile %}{{ section.settings.background_image_mobile | image_url }}{% endif %}"
  data-title-desktop="{{ section.settings.title | escape }}"
  data-title-mobile="{{ section.settings.title_mobile | escape }}"
  data-subtitle-desktop="{{ section.settings.subtitle | escape }}"
  data-subtitle-mobile="{{ section.settings.subtitle_mobile | escape }}"
  data-button-desktop="{{ section.settings.button_text | escape }}"
  data-button-mobile="{{ section.settings.button_text_mobile | escape }}"
  data-title-color-desktop="{{ section.settings.title_color }}"
  data-title-color-mobile="{{ section.settings.title_color_mobile }}"
  data-subtitle-color-desktop="{{ section.settings.subtitle_color }}"
  data-subtitle-color-mobile="{{ section.settings.subtitle_color_mobile }}"
  data-button-color-desktop="{{ section.settings.button_color }}"
  data-button-color-mobile="{{ section.settings.button_color_mobile }}"
>
    <div class="exclusive-content">
      <h2 class="exclusive-title" id="exclusive-title" style="color: {{ section.settings.title_color }}">{{ section.settings.title | default: 'This store is exclusive to Carvana employees & select customers' }}</h2>
      <p class="exclusive-subtitle" id="exclusive-subtitle" style="color: {{ section.settings.subtitle_color }}">{{ section.settings.subtitle | default: 'Please log in to access your account.' }}</p>
      <button class="btn-login" id="exclusive-btn" onclick="showLoginModal()" style="color: {{ section.settings.button_color }}">{{ section.settings.button_text | default: 'Login to your account' }}</button>
    </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var section = document.querySelector('.exclusive-section');
    if (!section) return;
    var titleEl = document.getElementById('exclusive-title');
    var subtitleEl = document.getElementById('exclusive-subtitle');
    var btnEl = document.getElementById('exclusive-btn');
    function setExclusiveContent() {
      var mobile = window.innerWidth <= 750;
      // Background
      var bg = mobile ? section.getAttribute('data-bg-mobile') : section.getAttribute('data-bg-desktop');
      if (bg) section.style.backgroundImage = 'url(' + bg + ')';
      // Title
      var title = mobile ? section.getAttribute('data-title-mobile') : section.getAttribute('data-title-desktop');
      if (title) titleEl.innerHTML = title;
      var titleColor = mobile ? section.getAttribute('data-title-color-mobile') : section.getAttribute('data-title-color-desktop');
      if (titleColor) titleEl.style.color = titleColor;
      // Subtitle
      var subtitle = mobile ? section.getAttribute('data-subtitle-mobile') : section.getAttribute('data-subtitle-desktop');
      if (subtitle) subtitleEl.innerHTML = subtitle;
      var subtitleColor = mobile ? section.getAttribute('data-subtitle-color-mobile') : section.getAttribute('data-subtitle-color-desktop');
      if (subtitleColor) subtitleEl.style.color = subtitleColor;
      // Button
      var btn = mobile ? section.getAttribute('data-button-mobile') : section.getAttribute('data-button-desktop');
      if (btn) btnEl.innerHTML = btn;
      var btnColor = mobile ? section.getAttribute('data-button-color-mobile') : section.getAttribute('data-button-color-desktop');
      if (btnColor) btnEl.style.color = btnColor;
    }
    setExclusiveContent();
    window.addEventListener('resize', setExclusiveContent);
  });
</script>

{% schema %}
{
  "name": "Exclusive Section",
  "tag": "section",
  "class": "exclusive-section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Background image for the entire section"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Mobile Background Image",
      "info": "Optional: background image for mobile (overrides desktop image on mobile)"
    },
    {
      "type": "html",
      "id": "title",
      "label": "Section Title",
      "default": "This store is exclusive to Carvana employees & select customers"
    },
    {
      "type": "html",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Please log in to access your account."
    },
    {
      "type": "html",
      "id": "button_text",
      "label": "Button Text",
      "default": "Login to your account"
    },
    {
      "type": "html",
      "id": "title_mobile",
      "label": "Mobile Section Title",
      "default": "This store is exclusive to Carvana employees & select customers"
    },
    {
      "type": "html",
      "id": "subtitle_mobile",
      "label": "Mobile Section Subtitle",
      "default": "Please log in to access your account."
    },
    {
      "type": "html",
      "id": "button_text_mobile",
      "label": "Mobile Button Text",
      "default": "Login to your account"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#183558"
    },
    {
      "type": "color",
      "id": "title_color_mobile",
      "label": "Mobile Title Color",
      "default": "#183558"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#183558"
    },
    {
      "type": "color",
      "id": "subtitle_color_mobile",
      "label": "Mobile Subtitle Color",
      "default": "#183558"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_color_mobile",
      "label": "Mobile Button Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Exclusive Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}
  