{%- comment -%}
  Custom Testimonials Section
  - Fully customizable: colors, text, background, alignment, spacing, etc.
  - Uses external CSS: section-custom-testimonials.css
  - Each testimonial is a block
{%- endcomment -%}

{{ 'section-custom-testimonials.css' | asset_url | stylesheet_tag }}
{{ 'swiper7.4.1.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper7.4.1.min.js' | asset_url }}" defer="defer" id="swiper-script"></script>
<script src="{{ 'component-custom-testimonials-slider.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign section_id = 'custom-testimonials-' | append: section.id
  assign testimonials_count = section.blocks.size
-%}

<custom-testimonials-slider data-section-id="{{ section.id }}">
<section id="{{ section_id }}" class="custom-testimonials-section" style="background: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="custom-testimonials__container" style="max-width: 95%;">
    <h2 class="custom-testimonials__heading" style="color: {{ section.settings.heading_color }}; text-align: {{ section.settings.heading_align }}; font-size: {{ section.settings.heading_size }}px; font-family: {{ section.settings.heading_font }};">
      {{ section.settings.heading }}
    </h2>
    <div class="custom-testimonials__swiper swiper" id="custom-testimonials-swiper-{{ section.id }}">
      <div class="custom-testimonials__grid swiper-wrapper cols-{{ section.settings.columns_desktop }} cols-tablet-{{ section.settings.columns_tablet }} cols-mobile-{{ section.settings.columns_mobile }}" style="gap: {{ section.settings.card_gap }}px;">
        {%- for block in section.blocks -%}
          <div class="custom-testimonials__card swiper-slide" style="background: {{ section.settings.card_bg }}; color: {{ section.settings.card_text_color }}; border-radius: {{ section.settings.card_radius }}px; box-shadow: {{ section.settings.card_shadow }}; border: {{ section.settings.card_border }}; padding: {{ section.settings.card_padding }}px;">
            <div class="custom-testimonials__quote" style="color: {{ section.settings.quote_color }}; font-size: {{ section.settings.quote_size }}px; text-align: {{ block.settings.quote_align }};">
              {%- if block.settings.quote_icon_img != blank -%}
                <img src="{{ block.settings.quote_icon_img | image_url: width: 80 }}"
                     alt="Quote Icon"
                     width="{{ block.settings.quote_icon_img_width | default: 40 }}"
                     style="display:inline-block;vertical-align:middle;margin-right:6px;width:{{ block.settings.quote_icon_img_width | default: 40 }}px;height:auto;max-height:60px;" />
              {%- endif -%}
              {{ section.settings.quote_icon }}
            </div>
            <div class="custom-testimonials__stars" style="color: {{ section.settings.star_color }}; font-size: {{ section.settings.star_size }}px; text-align: {{ block.settings.stars_align }};">
              {%- assign empty_stars_start = block.settings.stars | plus: 1 -%}
              {%- for i in (1..block.settings.stars) -%}<span>&#9733;</span>{%- endfor -%}
              {%- for i in (empty_stars_start..5) -%}<span style="color: {{ section.settings.star_empty_color }};">&#9733;</span>{%- endfor -%}
            </div>
            <div class="custom-testimonials__title" style="font-weight: bold; font-size: {{ section.settings.title_size }}px; text-align: {{ block.settings.title_align }}; margin-top: 0px;">
              {{ block.settings.title }}
            </div>
            <div class="custom-testimonials__text" style="font-size: {{ section.settings.text_size }}px; text-align: {{ block.settings.text_align }}; margin-top: 0px; font-style: italic;">
              {{ block.settings.text }}
            </div>
            <div class="custom-testimonials__author" style="font-size: {{ section.settings.author_size }}px; color: {{ section.settings.author_color }}; text-align: {{ block.settings.author_align }}; margin-top: 16px; font-weight: bold;">
              — {{ block.settings.author }}
            </div>
          </div>
        {%- endfor -%}
      </div>
      {%- if testimonials_count > 4 -%}
        <div class="custom-testimonials__swiper-nav custom-testimonials__swiper-prev swiper-button-prev"></div>
        <div class="custom-testimonials__swiper-nav custom-testimonials__swiper-next swiper-button-next"></div>
      {%- endif -%}
    </div>
  </div>
</section>
</custom-testimonials-slider>

{% schema %}
{
  "name": "Custom Testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "WHAT OTHER ARE SAYING" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#000000" },
    { "type": "range", "id": "heading_size", "label": "Heading Font Size (px)", "min": 18, "max": 48, "step": 1, "default": 32 },
    { "type": "select", "id": "heading_align", "label": "Heading Alignment", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ], "default": "center" },
    { "type": "text", "id": "heading_font", "label": "Heading Font Family", "default": "inherit" },
    { "type": "color", "id": "bg_color", "label": "Section Background Color", "default": "#fff" },
    { "type": "range", "id": "padding_top", "label": "Section Padding Top (px)", "min": 0, "max": 100, "step": 1, "default": 32 },
    { "type": "range", "id": "padding_bottom", "label": "Section Padding Bottom (px)", "min": 0, "max": 100, "step": 1, "default": 32 },
    { "type": "color", "id": "card_bg", "label": "Card Background Color", "default": "#fff" },
    { "type": "color", "id": "card_text_color", "label": "Card Text Color", "default": "#222" },
    { "type": "text", "id": "card_border", "label": "Card Border (CSS)", "default": "none" },
    { "type": "text", "id": "card_shadow", "label": "Card Box Shadow (CSS)", "default": "0 2px 8px rgba(0,0,0,0.04)" },
    { "type": "range", "id": "card_radius", "label": "Card Border Radius (px)", "min": 0, "max": 32, "step": 1, "default": 8 },
    { "type": "range", "id": "card_padding", "label": "Card Padding (px)", "min": 8, "max": 48, "step": 1, "default": 24 },
    { "type": "range", "id": "card_gap", "label": "Gap Between Cards (px)", "min": 0, "max": 48, "step": 1, "default": 24 },
    { "type": "range", "id": "columns_desktop", "label": "Columns on Desktop", "min": 1, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_tablet", "label": "Columns on Tablet", "min": 1, "max": 4, "step": 1, "default": 2 },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on Mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    { "type": "color", "id": "star_color", "label": "Star Color", "default": "#000" },
    { "type": "color", "id": "star_empty_color", "label": "Empty Star Color", "default": "#bbb" },
    { "type": "range", "id": "star_size", "label": "Star Size (px)", "min": 12, "max": 32, "step": 1, "default": 20 },
    { "type": "text", "id": "quote_icon", "label": "Quote Icon (HTML)", "default": "&#8220;&#8220;" },
    { "type": "color", "id": "quote_color", "label": "Quote Icon Color", "default": "#444" },
    { "type": "range", "id": "quote_size", "label": "Quote Icon Size (px)", "min": 16, "max": 48, "step": 1, "default": 32 },
    { "type": "range", "id": "title_size", "label": "Review Title Font Size (px)", "min": 12, "max": 32, "step": 1, "default": 18 },
    { "type": "range", "id": "text_size", "label": "Review Text Font Size (px)", "min": 10, "max": 24, "step": 1, "default": 14 },
    { "type": "color", "id": "author_color", "label": "Author Color", "default": "#000" },
    { "type": "range", "id": "author_size", "label": "Author Font Size (px)", "min": 10, "max": 24, "step": 1, "default": 14 },
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "text", "id": "title", "label": "Review Title", "default": "Review Title" },
        { "type": "textarea", "id": "text", "label": "Review Text", "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut posuere feugiat sapien, nec laoreet justo facilisis et." },
        { "type": "text", "id": "author", "label": "Author Name", "default": "NAME" },
        { "type": "range", "id": "stars", "label": "Star Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "select", "id": "quote_align", "label": "Quote Icon Alignment", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ], "default": "left" },
        { "type": "image_picker", "id": "quote_icon_img", "label": "Quote Icon Image (optional)" },
        { "type": "select", "id": "stars_align", "label": "Stars Alignment", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ], "default": "left" },
        { "type": "select", "id": "title_align", "label": "Title Alignment", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ], "default": "left" },
        { "type": "select", "id": "text_align", "label": "Text Alignment", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ], "default": "left" },
        { "type": "select", "id": "author_align", "label": "Author Alignment", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ], "default": "left" },
        { "type": "range", "id": "quote_icon_img_width", "label": "Quote Icon Image Width (px)", "min": 16, "max": 80, "step": 1, "default": 40 }
      ]
    }
  ],
  "presets": [
    { "name": "Custom Testimonials", "blocks": [ { "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" } ] }
  ]
}
{% endschema %} 

