<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}
    {%- unless settings.type_heading_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    <style>
      .first-visit-overlay {
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        font: 16px/1.4 system-ui, sans-serif;
        opacity: 1;
        visibility: visible;
        transition: opacity 250ms ease;
        z-index: 9999;
      }

      .first-visit-overlay[data-hidden='true'],
      .first-visit-returning .first-visit-overlay {
        opacity: 0;
        visibility: hidden;
      }
    </style>

    <script>
      (() => {
        try {
          if (sessionStorage.getItem('firstVisitSeen')) {
            document.documentElement.classList.add('first-visit-returning');
          }
        } catch (_error) {
          document.documentElement.classList.add('first-visit-returning');
        }
      })();
    </script>


    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}

    <script src="{{ 'alpinejs-persist@3.14.8.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'alpinejs@3.14.8.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'theme.js' | asset_url }}" type="module"></script>



    {% comment %} liquid-ajax-cart.js.org {% endcomment %}
    <script type="application/json" data-ajax-cart-initial-state>
      {{ cart | json }}
    </script>

    <script type="module">
      import '{{ "liquid-ajax-cart-v2.1.1.js" | asset_url }}';
    </script>


    {%- if settings.predictive_search_enabled -%}
      {{ 'component-predictive-search.css' | asset_url | stylesheet_tag }}
    {%- endif -%}
  </head>

  <body>
    <a class="skip-to-content-link visually-hidden" href="#MainContent">
      Skip to content
    </a>

    <div class="first-visit-overlay" id="FirstVisitOverlay">
      <p>{{ 'general.first_visit_overlay.message' | t }}</p>
    </div>

    {% sections 'header-group' %}

    <main id="MainContent" class="content-for-layout" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- if settings.predictive_search_enabled -%}
      <script src="{{ 'component-predictive-search.js' | asset_url }}" type="module"></script>
    {%- endif -%}

    <script>
      (() => {
        const STORAGE_KEY = 'firstVisitSeen';
        const overlay = document.getElementById('FirstVisitOverlay');
        const root = document.documentElement;

        if (!overlay) return;

        let hasSeen = false;

        try {
          hasSeen = Boolean(sessionStorage.getItem(STORAGE_KEY));
        } catch (_error) {
          overlay.setAttribute('data-hidden', 'true');
          overlay.remove();
          return;
        }

        const hideOverlay = () => {
          overlay.setAttribute('data-hidden', 'true');
          sessionStorage.setItem(STORAGE_KEY, '1');
          root.classList.add('first-visit-returning');
          setTimeout(() => overlay.remove(), 250);
        };

        if (hasSeen) {
          root.classList.add('first-visit-returning');
          overlay.remove();
          return;
        }

        window.addEventListener(
          'load',
          () => {
            setTimeout(hideOverlay, 600);
          },
          { once: true }
        );
      })();
    </script>
  </body>
</html>