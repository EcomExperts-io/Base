{% liquid
  assign overlay_storage_key = settings.first_visit_overlay_storage_key | default: 'firstVisitSeen'
%}
<script>
  (() => {
    const storageKey = {{ overlay_storage_key | json }};

    if (!storageKey) return;

    try {
      if (sessionStorage.getItem(storageKey)) {
        document.documentElement.classList.add('first-visit-returning');
      }
    } catch (_error) {
      document.documentElement.classList.add('first-visit-returning');
    }
  })();
</script>

